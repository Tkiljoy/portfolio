---
const links = [
  { href: "/#work", label: "Work" },
  { href: "/#journey", label: "Journey" },
  { href: "/ux", label: "Prison UX", deep: true },
  { href: "/banking", label: "Banking", deep: true },
  { href: "/#about", label: "About" },
  { href: "/#contact", label: "Contact" },
];
---

<header class="fixed inset-x-0 top-0 z-40 border-b border-line/70 bg-bg/80 backdrop-blur-md">
  <nav
    aria-label="Primary"
    class="mx-auto flex h-14 max-w-5xl items-center justify-between px-5 sm:px-8"
  >
    <a
      href="/#top"
      class="font-display text-sm font-bold tracking-tight text-ink transition-colors hover:text-accent"
    >
      KR<span class="text-accent">.</span>
    </a>
    <div class="flex items-center gap-5 sm:gap-8">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              "font-mono text-xs tracking-wide text-muted transition-colors hover:text-ink",
              link.deep && "hidden sm:inline-block",
            ]}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="/resume.pdf"
        download="Kristepher-Reed-Resume.pdf"
        class="hidden border border-line px-3 py-1.5 font-mono text-xs tracking-wide text-ink transition-colors hover:border-accent hover:text-accent sm:inline-block"
      >
        Resume
      </a>
    </div>
  </nav>
</header>
