---
interface CaseStudy {
  title: string;
  detail: string;
}

interface Props {
  index: number;
  title: string;
  meta: string;
  tags: string[];
  copy: string;
  link?: { href: string; label: string };
  asset?: string; // label for the placeholder slot, omitted = no media
  caseStudies?: CaseStudy[];
}

const { index, title, meta, tags, copy, link, asset, caseStudies } = Astro.props;
const number = String(index).padStart(2, "0");
---

<article data-reveal class="border-t border-line py-12 sm:py-16">
  <div class="grid gap-6 md:grid-cols-[8rem_1fr] md:gap-10">
    <div class="flex items-baseline gap-4 md:block">
      <span aria-hidden="true" class="font-display text-2xl font-bold text-faint">{number}</span>
      <p class="font-mono text-xs leading-relaxed text-ember md:mt-3">{meta}</p>
    </div>

    <div>
      <h3 class="font-display text-2xl font-bold tracking-tight text-ink sm:text-3xl">
        {title}
      </h3>

      <ul class="mt-4 flex flex-wrap gap-2" aria-label="Technologies">
        {
          tags.map((tag) => (
            <li class="border border-line bg-surface px-2.5 py-1 font-mono text-[11px] text-muted">
              {tag}
            </li>
          ))
        }
      </ul>

      <p class="mt-5 max-w-2xl leading-relaxed text-muted">{copy}</p>

      {
        caseStudies && (
          <ul class="mt-6 max-w-2xl space-y-3">
            {caseStudies.map((cs) => (
              <li class="border-l-2 border-ember/60 pl-4">
                <span class="font-medium text-ink">{cs.title}:</span>
                <span class="text-muted"> {cs.detail}</span>
              </li>
            ))}
          </ul>
        )
      }

      {
        asset && (
          <div
            class="hatch mt-7 flex aspect-video max-w-2xl items-center justify-center border border-dashed border-line bg-surface"
            role="img"
            aria-label={`${title} — ${asset} coming soon`}
          >
            <span class="px-4 text-center font-mono text-xs text-faint">{asset}</span>
          </div>
        )
      }

      {
        link && (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group mt-7 inline-flex items-center gap-2 font-mono text-sm text-ink transition-colors hover:text-ember"
          >
            {link.label}
            <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">
              →
            </span>
          </a>
        )
      }
    </div>
  </div>
</article>
