---
const links = [
  { href: "https://github.com/Tkiljoy", label: "GitHub", external: true },
  { href: "https://www.linkedin.com/in/kristepher-reed", label: "LinkedIn", external: true },
  { href: "mailto:krisreed2001@gmail.com", label: "Email", external: false },
];

const ticker = [
  "React",
  "TypeScript",
  "JavaScript",
  "Lua",
  "Python",
  "SQL",
  "Astro",
  "Node.js",
  "Fastify",
  "n8n",
  "Claude API",
  "MCP",
];
---

<section id="top" class="relative overflow-hidden">
  <!-- Blueprint grid, fading out from the top -->
  <div
    aria-hidden="true"
    class="bg-grid pointer-events-none absolute inset-0 [mask-image:radial-gradient(ellipse_80%_70%_at_50%_0%,black,transparent)]"
  >
  </div>
  <!-- Particle network -->
  <canvas id="hero-net" aria-hidden="true" class="absolute inset-0 h-full w-full"></canvas>
  <!-- Glow blobs -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -top-44 right-[-15%] h-[36rem] w-[36rem] rounded-full opacity-25 blur-3xl"
    style="background: radial-gradient(closest-side, #8b5cf6, transparent 70%);"
  >
  </div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -bottom-56 left-[-18%] h-[32rem] w-[32rem] rounded-full opacity-15 blur-3xl"
    style="background: radial-gradient(closest-side, #e879f9, transparent 70%);"
  >
  </div>

  <div class="relative mx-auto max-w-5xl px-5 pt-32 pb-16 sm:px-8 sm:pt-44 sm:pb-24">
    <p
      data-reveal
      class="mb-8 inline-flex items-center gap-2.5 border border-line bg-surface/80 px-3 py-1.5 font-mono text-xs text-muted"
    >
      <span class="relative inline-block h-1.5 w-1.5 rounded-full bg-accent pulse-dot"></span>
      Remote · South Dakota · Available immediately
    </p>

    <h1
      class="font-display text-5xl leading-[0.92] font-black tracking-tight text-ink uppercase sm:text-8xl md:text-[7.5rem]"
    >
      <span class="block overflow-hidden"><span class="title-line block">Kristepher</span></span>
      <span class="block overflow-hidden">
        <span class="title-line title-line-2 text-gradient-anim block pb-2">Reed.</span>
      </span>
    </h1>

    <p
      data-reveal
      style="--reveal-delay: 0.16s"
      class="mt-9 font-mono text-sm leading-relaxed text-accent-soft uppercase sm:text-base"
    >
      <span data-scramble>Full-Stack Developer</span>
      <span aria-hidden="true" class="text-accent">//</span>
      <span data-scramble>Game Systems Engineer</span>
      <span aria-hidden="true" class="text-accent">//</span>
      <span data-scramble>AI Automation Builder</span>
    </p>

    <p
      data-reveal
      style="--reveal-delay: 0.24s"
      class="mt-5 max-w-2xl text-xl leading-relaxed text-muted sm:text-2xl"
    >
      I build production software people pay for — solo, end-to-end, for six years.
    </p>

    <ul data-reveal style="--reveal-delay: 0.32s" class="mt-10 flex flex-wrap items-center gap-3">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
              class="inline-block border border-line bg-surface/60 px-4 py-2 font-mono text-sm text-ink transition-all hover:border-accent hover:text-accent hover:shadow-[0_0_24px_-6px_rgba(168,85,247,0.6)]"
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li>
        <a
          href="/resume.pdf"
          download="Kristepher-Reed-Resume.pdf"
          class="inline-block bg-accent px-4 py-2 font-mono text-sm font-semibold text-bg transition-all hover:bg-accent-soft hover:shadow-[0_0_32px_-6px_rgba(168,85,247,0.8)]"
        >
          Resume ↓
        </a>
      </li>
    </ul>
  </div>

  <!-- Skills ticker -->
  <div class="marquee relative border-y border-line bg-surface/40 py-3" aria-hidden="true">
    <div class="marquee-track">
      {
        [0, 1].map(() => (
          <div class="flex shrink-0 items-center">
            {ticker.map((item) => (
              <span class="flex items-center font-mono text-xs tracking-[0.25em] text-muted uppercase">
                <span class="px-5 text-accent">✦</span>
                {item}
              </span>
            ))}
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  // Particle constellation in the hero. Skipped entirely under
  // prefers-reduced-motion; paused while the hero is offscreen.
  const canvas = document.getElementById("hero-net") as HTMLCanvasElement | null;
  if (canvas && !matchMedia("(prefers-reduced-motion: reduce)").matches) {
    const ctx = canvas.getContext("2d");
    if (ctx) {
      const LINK_DIST = 120;
      const MOUSE_R = 150;
      let w = 0;
      let h = 0;
      let raf = 0;
      let running = false;
      const mouse = { x: -9999, y: -9999 };

      type P = { x: number; y: number; vx: number; vy: number; r: number; hot: boolean };
      let particles: P[] = [];

      const resize = () => {
        const rect = canvas.getBoundingClientRect();
        const dpr = Math.min(devicePixelRatio || 1, 2);
        w = rect.width;
        h = rect.height;
        canvas.width = w * dpr;
        canvas.height = h * dpr;
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        const count = w < 640 ? 32 : 72;
        particles = Array.from({ length: count }, () => ({
          x: Math.random() * w,
          y: Math.random() * h,
          vx: (Math.random() - 0.5) * 0.35,
          vy: (Math.random() - 0.5) * 0.35,
          r: Math.random() * 1.4 + 0.8,
          hot: Math.random() < 0.18,
        }));
      };

      const step = () => {
        ctx.clearRect(0, 0, w, h);
        for (const p of particles) {
          p.x += p.vx;
          p.y += p.vy;
          // gentle repulsion from the cursor
          const dx = p.x - mouse.x;
          const dy = p.y - mouse.y;
          const d2 = dx * dx + dy * dy;
          if (d2 < MOUSE_R * MOUSE_R && d2 > 0.01) {
            const d = Math.sqrt(d2);
            const f = ((MOUSE_R - d) / MOUSE_R) * 0.6;
            p.x += (dx / d) * f;
            p.y += (dy / d) * f;
          }
          if (p.x < 0) p.x += w;
          if (p.x > w) p.x -= w;
          if (p.y < 0) p.y += h;
          if (p.y > h) p.y -= h;
        }
        for (let i = 0; i < particles.length; i++) {
          for (let j = i + 1; j < particles.length; j++) {
            const a = particles[i];
            const b = particles[j];
            const dx = a.x - b.x;
            const dy = a.y - b.y;
            const d2 = dx * dx + dy * dy;
            if (d2 < LINK_DIST * LINK_DIST) {
              const alpha = (1 - Math.sqrt(d2) / LINK_DIST) * 0.22;
              ctx.strokeStyle = `rgba(168, 85, 247, ${alpha})`;
              ctx.lineWidth = 1;
              ctx.beginPath();
              ctx.moveTo(a.x, a.y);
              ctx.lineTo(b.x, b.y);
              ctx.stroke();
            }
          }
        }
        for (const p of particles) {
          ctx.fillStyle = p.hot ? "rgba(232, 121, 249, 0.85)" : "rgba(201, 168, 255, 0.65)";
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
          ctx.fill();
        }
        raf = requestAnimationFrame(step);
      };

      const section = canvas.closest("section");
      section?.addEventListener(
        "pointermove",
        (e) => {
          const rect = canvas.getBoundingClientRect();
          mouse.x = e.clientX - rect.left;
          mouse.y = e.clientY - rect.top;
        },
        { passive: true },
      );
      section?.addEventListener("pointerleave", () => {
        mouse.x = -9999;
        mouse.y = -9999;
      });

      new IntersectionObserver((entries) => {
        const visible = entries[0]?.isIntersecting ?? false;
        if (visible && !running) {
          running = true;
          raf = requestAnimationFrame(step);
        } else if (!visible && running) {
          running = false;
          cancelAnimationFrame(raf);
        }
      }).observe(canvas);

      // Size immediately, then let ResizeObserver correct it once layout
      // settles (load-time layout can report a 0-width canvas) and on
      // window resizes. The timer retry covers environments where RO
      // callbacks are throttled or suspended.
      resize();
      if (canvas.width === 0) {
        const retry = setInterval(() => {
          resize();
          if (canvas.width > 0) clearInterval(retry);
        }, 150);
        setTimeout(() => clearInterval(retry), 5000);
      }
      new ResizeObserver(() => resize()).observe(canvas);
    }
  }
</script>
