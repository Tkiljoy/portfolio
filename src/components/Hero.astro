---
const links = [
  { href: "https://github.com/Tkiljoy", label: "GitHub", external: true },
  { href: "https://www.linkedin.com/in/kristepher-reed", label: "LinkedIn", external: true },
  { href: "mailto:krisreed2001@gmail.com", label: "Email", external: false },
];

const ticker = [
  "React",
  "TypeScript",
  "JavaScript",
  "Lua",
  "Python",
  "SQL",
  "Astro",
  "Electron",
  "FastAPI",
  "n8n",
  "Claude API",
  "MCP",
];
---

<section id="top" class="relative overflow-hidden">
  <!-- Blueprint grid, fading out from the top -->
  <div
    aria-hidden="true"
    class="bg-grid pointer-events-none absolute inset-0 [mask-image:radial-gradient(ellipse_80%_70%_at_50%_0%,black,transparent)]"
  >
  </div>
  <!-- Glow blobs -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -top-44 right-[-15%] h-[36rem] w-[36rem] rounded-full opacity-25 blur-3xl"
    style="background: radial-gradient(closest-side, #8b5cf6, transparent 70%);"
  >
  </div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -bottom-56 left-[-18%] h-[32rem] w-[32rem] rounded-full opacity-15 blur-3xl"
    style="background: radial-gradient(closest-side, #e879f9, transparent 70%);"
  >
  </div>

  <div class="relative mx-auto max-w-5xl px-5 pt-32 pb-16 sm:px-8 sm:pt-44 sm:pb-24">
    <p
      data-reveal
      class="mb-8 inline-flex items-center gap-2.5 border border-line bg-surface/80 px-3 py-1.5 font-mono text-xs text-muted"
    >
      <span class="relative inline-block h-1.5 w-1.5 rounded-full bg-accent pulse-dot"></span>
      Remote · South Dakota · Available immediately
    </p>

    <h1
      data-reveal
      style="--reveal-delay: 0.08s"
      class="font-display text-5xl leading-[0.92] font-black tracking-tight text-ink uppercase sm:text-8xl md:text-[7.5rem]"
    >
      Kristepher<br /><span class="text-gradient">Reed.</span>
    </h1>

    <p
      data-reveal
      style="--reveal-delay: 0.16s"
      class="mt-9 font-mono text-sm leading-relaxed text-accent-soft uppercase sm:text-base"
    >
      Full-Stack Developer <span aria-hidden="true" class="text-accent">//</span> Game Systems
      Engineer <span aria-hidden="true" class="text-accent">//</span> AI Automation Builder
    </p>

    <p
      data-reveal
      style="--reveal-delay: 0.24s"
      class="mt-5 max-w-2xl text-xl leading-relaxed text-muted sm:text-2xl"
    >
      I build production software people pay for — solo, end-to-end, for six years.
    </p>

    <ul data-reveal style="--reveal-delay: 0.32s" class="mt-10 flex flex-wrap items-center gap-3">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
              class="inline-block border border-line bg-surface/60 px-4 py-2 font-mono text-sm text-ink transition-all hover:border-accent hover:text-accent hover:shadow-[0_0_24px_-6px_rgba(168,85,247,0.6)]"
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li>
        <a
          href="/resume.pdf"
          download="Kristepher-Reed-Resume.pdf"
          class="inline-block bg-accent px-4 py-2 font-mono text-sm font-semibold text-bg transition-all hover:bg-accent-soft hover:shadow-[0_0_32px_-6px_rgba(168,85,247,0.8)]"
        >
          Resume ↓
        </a>
      </li>
    </ul>
  </div>

  <!-- Skills ticker -->
  <div class="marquee relative border-y border-line bg-surface/40 py-3" aria-hidden="true">
    <div class="marquee-track">
      {
        [0, 1].map(() => (
          <div class="flex shrink-0 items-center">
            {ticker.map((item) => (
              <span class="flex items-center font-mono text-xs tracking-[0.25em] text-muted uppercase">
                <span class="px-5 text-accent">✦</span>
                {item}
              </span>
            ))}
          </div>
        ))
      }
    </div>
  </div>
</section>
