---
import SectionHeading from "./SectionHeading.astro";

// `count` drives the count-up animation; prefix/suffix/format shape the text.
const stats = [
  { count: 6, suffix: "+", label: "years professional" },
  { count: 30, suffix: "+", label: "products shipped" },
  { count: 30, prefix: "$", suffix: "k+", label: "annual revenue" },
  { count: 1000, suffix: "+", format: "comma", label: "paying customers" },
];

const milestones = [
  {
    year: "2014",
    title: "First lines of code",
    detail:
      "Self-taught start — game modding and web basics. No bootcamp, no roadmap, just shipping things to see if they work.",
  },
  {
    year: "2020",
    title: "Went professional",
    detail:
      "Started taking paid work — 50+ commissioned scripts and gameplay systems for content creators with 5,000,000+ subscriber audiences. The only engineer in the room from day one.",
  },
  {
    year: "2022",
    title: "Founded Dragon Heart Studios",
    detail:
      "Self-funded digital products studio. First paying customers, then a 2,000+ member community around the catalog.",
  },
  {
    year: "2023",
    title: "District 77 platform",
    detail:
      "Became lead developer for District 77, a live online multiplayer community of 1,000+ members — owning server architecture and feature delivery, and building its member platform (forum + storefront) from scratch.",
  },
  {
    year: "2025",
    title: "Commercial catalogue",
    detail:
      "Prison Simulation System and Petty Crime System — full gameplay loops with progression, persistence, and economy. Running live on multiplayer servers today.",
  },
  {
    year: "2026",
    title: "The AI chapter",
    detail:
      "DHS-Lair — a self-hosted multi-agent AI orchestration platform — plus co-founding Zyntho (AI automation agency) and shipping DHS-BankingSim, a full player-driven banking economy.",
  },
];
---

<section id="journey" class="relative scroll-mt-14 overflow-hidden border-t border-line">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute top-1/3 left-[-18%] h-[30rem] w-[30rem] rounded-full opacity-15 blur-3xl"
    style="background: radial-gradient(closest-side, #8b5cf6, transparent 70%);"
  >
  </div>

  <div class="relative mx-auto max-w-5xl px-5 py-20 sm:px-8 sm:py-28">
    <SectionHeading num="02" title="The Road Here" ghost="Road" />

    <!-- Stat strip -->
    <dl
      data-reveal
      class="mb-16 grid grid-cols-2 gap-px border border-line bg-line sm:mb-20 lg:grid-cols-4"
    >
      {
        stats.map((stat) => (
          <div class="bg-surface px-5 py-6 sm:px-7 sm:py-8">
            <dd
              class="text-gradient font-display text-3xl font-black tracking-tight sm:text-5xl"
              data-countup={stat.count}
              data-prefix={stat.prefix}
              data-suffix={stat.suffix}
              data-format={stat.format}
            >
              {stat.prefix}{stat.format === "comma" ? stat.count.toLocaleString("en-US") : stat.count}{stat.suffix}
            </dd>
            <dt class="mt-2 font-mono text-xs tracking-wide text-muted uppercase">{stat.label}</dt>
          </div>
        ))
      }
    </dl>

    <!-- Timeline -->
    <ol class="relative ml-2 sm:ml-4">
      <!-- Gradient spine -->
      <div
        aria-hidden="true"
        class="absolute top-1 bottom-1 left-0 w-px"
        style="background: linear-gradient(to bottom, #8b5cf6, #a855f7 50%, #e879f9);"
      >
      </div>

      {
        milestones.map((m, i) => (
          <li
            data-reveal
            style={`--reveal-delay: ${i * 0.07}s`}
            class="group relative pb-12 pl-8 last:pb-0 sm:pl-12"
          >
            <span
              aria-hidden="true"
              class="absolute top-1.5 -left-[5px] h-[11px] w-[11px] rounded-full border-2 border-accent bg-bg transition-all duration-300 group-hover:bg-accent group-hover:shadow-[0_0_16px_2px_rgba(168,85,247,0.6)]"
            />
            <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1">
              <span class="font-mono text-sm font-medium text-accent-soft">{m.year}</span>
              <h3 class="font-display text-xl font-bold tracking-tight text-ink sm:text-2xl">
                {m.title}
              </h3>
            </div>
            <p class="mt-2 max-w-2xl leading-relaxed text-muted">{m.detail}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
