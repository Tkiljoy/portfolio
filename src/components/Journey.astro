---
// Dates/figures marked [verify] are best guesses — Kris to confirm.
const stats = [
  { value: "6+", label: "years professional" },
  { value: "30+", label: "products shipped" }, // [verify]
  { value: "$30k+", label: "annual revenue" },
  { value: "1,000+", label: "paying customers" },
];

const milestones = [
  {
    year: "2014",
    title: "First lines of code",
    detail:
      "Self-taught start — game modding and web basics. No bootcamp, no roadmap, just shipping things to see if they work.", // [verify year]
  },
  {
    year: "2020",
    title: "Went professional",
    detail:
      "Coursework at Neumont College of Computer Science, then straight into paid work — the only engineer in the room from day one.",
  },
  {
    year: "2022",
    title: "Founded Dragon Heart Studios",
    detail:
      "Self-funded digital products studio. First paying customers, then a 2,000+ member community around the catalog.",
  },
  {
    year: "2023",
    title: "District 77 platform",
    detail:
      "Built a combined forum + e-commerce store for a 1,000+ member multiplayer community. From scratch — no CMS, no templates.",
  },
  {
    year: "2025",
    title: "Prison Simulation System",
    detail:
      "Flagship commercial release — full gameplay loop with progression, persistence, and economy. Running live on multiplayer servers today.",
  },
  {
    year: "2026",
    title: "The AI chapter",
    detail:
      "ReeMain Automations — 27 production workflows for SMB clients — and DHS-Lair, a voice-driven desktop assistant with an LLM core.",
  },
];
---

<section id="journey" class="relative scroll-mt-14 overflow-hidden border-t border-line">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute top-1/3 left-[-18%] h-[30rem] w-[30rem] rounded-full opacity-15 blur-3xl"
    style="background: radial-gradient(closest-side, #8b5cf6, transparent 70%);"
  >
  </div>

  <div class="relative mx-auto max-w-5xl px-5 py-20 sm:px-8 sm:py-28">
    <div data-reveal class="mb-10 flex flex-wrap items-baseline gap-x-5 gap-y-2 sm:mb-14">
      <span class="font-mono text-sm text-accent">(02)</span>
      <h2 class="font-display text-4xl font-extrabold tracking-tight text-ink sm:text-6xl">
        The Road Here
      </h2>
    </div>

    <!-- Stat strip -->
    <dl
      data-reveal
      class="mb-16 grid grid-cols-2 gap-px border border-line bg-line sm:mb-20 lg:grid-cols-4"
    >
      {
        stats.map((stat) => (
          <div class="bg-surface px-5 py-6 sm:px-7 sm:py-8">
            <dd class="text-gradient font-display text-3xl font-black tracking-tight sm:text-5xl">
              {stat.value}
            </dd>
            <dt class="mt-2 font-mono text-xs tracking-wide text-muted uppercase">{stat.label}</dt>
          </div>
        ))
      }
    </dl>

    <!-- Timeline -->
    <ol class="relative ml-2 sm:ml-4">
      <!-- Gradient spine -->
      <div
        aria-hidden="true"
        class="absolute top-1 bottom-1 left-0 w-px"
        style="background: linear-gradient(to bottom, #8b5cf6, #a855f7 50%, #e879f9);"
      >
      </div>

      {
        milestones.map((m, i) => (
          <li
            data-reveal
            style={`--reveal-delay: ${i * 0.07}s`}
            class="group relative pb-12 pl-8 last:pb-0 sm:pl-12"
          >
            <span
              aria-hidden="true"
              class="absolute top-1.5 -left-[5px] h-[11px] w-[11px] rounded-full border-2 border-accent bg-bg transition-all duration-300 group-hover:bg-accent group-hover:shadow-[0_0_16px_2px_rgba(168,85,247,0.6)]"
            />
            <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1">
              <span class="font-mono text-sm font-medium text-accent-soft">{m.year}</span>
              <h3 class="font-display text-xl font-bold tracking-tight text-ink sm:text-2xl">
                {m.title}
              </h3>
            </div>
            <p class="mt-2 max-w-2xl leading-relaxed text-muted">{m.detail}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
