---
import CopyEmail from "./CopyEmail";
---

<section id="contact" class="relative scroll-mt-14 overflow-hidden border-t border-line">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -bottom-48 right-[-10%] h-[28rem] w-[28rem] rounded-full opacity-15 blur-3xl"
    style="background: radial-gradient(closest-side, #8b5cf6, transparent 70%);"
  >
  </div>

  <div class="relative mx-auto max-w-5xl px-5 py-20 sm:px-8 sm:py-28">
    <div data-reveal class="mb-10 flex flex-wrap items-baseline gap-x-5 gap-y-2 sm:mb-14">
      <span class="font-mono text-sm text-accent">(03)</span>
      <h2 class="font-display text-4xl font-extrabold tracking-tight text-ink sm:text-6xl">
        Contact
      </h2>
    </div>

    <p
      data-reveal
      class="max-w-3xl font-display text-3xl leading-tight font-bold tracking-tight text-ink sm:text-5xl"
    >
      Hiring? I can start contributing <span class="text-gradient">this week</span>.
    </p>

    <div data-reveal style="--reveal-delay: 0.1s" class="mt-10 flex flex-wrap items-center gap-3">
      <a
        href="mailto:krisreed2001@gmail.com"
        class="inline-block bg-accent px-5 py-2.5 font-mono text-sm font-semibold text-bg transition-all hover:bg-accent-soft hover:shadow-[0_0_32px_-6px_rgba(168,85,247,0.8)]"
      >
        krisreed2001@gmail.com
      </a>
      <CopyEmail client:visible />
      <a
        href="/resume.pdf"
        download="Kristepher-Reed-Resume.pdf"
        class="inline-block border border-line px-4 py-2 font-mono text-sm text-muted transition-colors hover:border-accent hover:text-accent"
      >
        Resume ↓
      </a>
    </div>
  </div>
</section>

<footer class="border-t border-line">
  <div
    class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-4 px-5 py-6 sm:px-8"
  >
    <p class="font-mono text-xs text-muted">© 2026 Kristepher Reed</p>
    <div class="flex items-center gap-5">
      <a
        href="https://github.com/Tkiljoy"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="text-muted transition-colors hover:text-accent"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55 0-.27-.01-1.17-.02-2.12-3.2.7-3.88-1.36-3.88-1.36-.52-1.33-1.28-1.68-1.28-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.19 1.76 1.19 1.03 1.76 2.69 1.25 3.35.96.1-.75.4-1.25.72-1.54-2.55-.29-5.24-1.28-5.24-5.68 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.17 1.18a11 11 0 0 1 5.78 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.83 1.19 3.09 0 4.41-2.69 5.38-5.26 5.66.41.36.78 1.06.78 2.14 0 1.54-.01 2.78-.01 3.16 0 .31.21.67.8.55C20.22 21.38 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5Z"
          ></path>
        </svg>
      </a>
      <a
        href="https://www.linkedin.com/in/kristepher-reed"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="text-muted transition-colors hover:text-accent"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12ZM7.12 20.45H3.55V9h3.57v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0Z"
          ></path>
        </svg>
      </a>
    </div>
  </div>
</footer>
