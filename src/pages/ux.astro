---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import SectionHeading from "../components/SectionHeading.astro";

// Claims below are verified against the shipped V1 source (branch `main`,
// v1.2.11). The V2 section reflects the in-development rewrite (branch `V2`).

const methods = [
  "2,000+ member Discord community",
  "Support ticket analysis",
  "Live server observation",
  "Operator pre-sales questions",
  "Competitor teardown",
];

const findings = [
  {
    n: "01",
    insight: "A sentence was dead time — players just logged out.",
    evidence:
      "Watching live servers: arrested players tabbed out, went AFK, or disconnected. The sentence punished the person at the keyboard, not the character.",
    decision:
      "Fill the sentence with a mandatory daily schedule — rollcall, meals, work, yard, showers — and make showing up matter: miss the mandatory blocks and the prison escalates to lockdown, then solitary.",
  },
  {
    n: "02",
    insight: "Players ignore anything without an on-screen payoff.",
    evidence:
      "Feedback on earlier scripts was consistent — systems with no visible result went unused within weeks.",
    decision:
      "Optional work jobs that visibly chip time off the sentence and pay commissary cash, with the countdown always on screen. Every action returns an immediate, legible result: less time, more money.",
  },
  {
    n: "03",
    insight: "Operators buy compatibility, not features.",
    evidence:
      "The #1 pre-sales question was never about gameplay — it was “does this work with my framework, inventory, and map?”",
    decision:
      "A framework bridge (QBCore / ESX / QBox), MLO-agnostic config that ships with two prison layouts, and one file of safe defaults. Install friction is a UX problem, and the operator is a user too.",
  },
  {
    n: "04",
    insight: "Support load clusters at first contact.",
    evidence:
      "Ticket analysis across the catalog: most tickets came from install and first-run config, not from bugs in play.",
    decision:
      "Defaults that work with zero edits, loud and specific error messages, and docs ordered by the first ten minutes of ownership.",
  },
];

const personas = [
  {
    initials: "SO",
    name: "The Server Operator",
    role: "Buys, installs, and runs the product",
    quote: "I run a city of 200 players. If your script breaks my server, it's gone by tonight.",
    goals: [
      "Drop-in install that fits their framework and map",
      "Config without touching code",
      "Keeps inmates busy without staff babysitting",
    ],
    frustrations: [
      "Scripts that fight their stack",
      "Support that vanishes after purchase",
      "Features players never touch",
    ],
  },
  {
    initials: "RP",
    name: "The Roleplay Player",
    role: "Lives inside the sentence",
    quote: "Getting arrested used to mean alt-tab for twenty minutes. Now there's a routine to run and time to work off.",
    goals: [
      "Something to do for the whole sentence",
      "Visible payoff — time worked off, cash earned",
      "Stakes worth the risk — work it out, or run",
    ],
    frustrations: [
      "Dead time and AFK timers",
      "Grind with no visible result",
      "Getting stuck with nothing to do",
    ],
  },
];

const wireframeNote =
  "Lo-fi structure, not pixels — these established hierarchy and flow before any styling.";

const v2 = [
  "Any prison, any map — facilities are authored as data-driven blueprints, not hardcoded coordinates.",
  "A full pipeline — police booking and charges, sentencing to jail or community service, and escorted transport into intake.",
  "Trust-tier work, gangs and territory, and a contraband economy with stash points and search checkpoints.",
  "DOC ranks and a warden layer on a real permission model — server owners configure authority, not code.",
];
---

<Layout
  title="UX Case Study — Kristepher Reed"
  description="End-to-end UX case study: research, personas, user flows, wireframes, and shipped UI for a live commercial game system."
>
  <Nav />
  <main id="main">
    <!-- Intro -->
    <section class="relative overflow-hidden">
      <div
        aria-hidden="true"
        class="bg-grid pointer-events-none absolute inset-0 [mask-image:radial-gradient(ellipse_80%_60%_at_50%_0%,black,transparent)]"
      >
      </div>
      <div
        aria-hidden="true"
        class="pointer-events-none absolute -top-40 right-[-15%] h-[30rem] w-[30rem] rounded-full opacity-20 blur-3xl"
        style="background: radial-gradient(closest-side, #8b5cf6, transparent 70%);"
      >
      </div>
      <div class="relative mx-auto max-w-5xl px-5 pt-32 pb-12 sm:px-8 sm:pt-40 sm:pb-16">
        <p data-reveal class="font-mono text-xs tracking-[0.25em] text-accent uppercase">
          UX Case Study
        </p>
        <h1
          data-reveal
          style="--reveal-delay: 0.08s"
          class="mt-4 font-display text-4xl leading-[0.95] font-black tracking-tight text-ink sm:text-6xl md:text-7xl"
        >
          Prison Simulation System<span class="text-gradient">.</span>
        </h1>
        <p
          data-reveal
          style="--reveal-delay: 0.16s"
          class="mt-6 max-w-2xl text-lg leading-relaxed text-muted sm:text-xl"
        >
          The end-to-end process behind a live commercial product — research, personas, flows,
          wireframes, and the shipped UI. Solo across every discipline: I was the researcher, the
          designer, and the engineer.
        </p>
        <dl
          data-reveal
          style="--reveal-delay: 0.24s"
          class="mt-8 grid max-w-2xl grid-cols-2 gap-px border border-line bg-line sm:grid-cols-4"
        >
          {
            [
              ["Role", "Solo — UX to ship"],
              ["Year", "2025"],
              ["Status", "Live & selling"],
              ["Platform", "Multiplayer servers"],
            ].map(([dt, dd]) => (
              <div class="bg-surface px-4 py-3">
                <dt class="font-mono text-[10px] tracking-[0.2em] text-faint uppercase">{dt}</dt>
                <dd class="mt-1 font-mono text-xs text-ink">{dd}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </section>

    <!-- Research -->
    <section class="overflow-hidden border-t border-line">
      <div class="mx-auto max-w-5xl px-5 py-16 sm:px-8 sm:py-24">
        <SectionHeading num="01" title="Research" ghost="Research" />
        <p data-reveal class="max-w-2xl leading-relaxed text-muted">
          No lab, no recruiting budget — research came from running a 2,000+ member community
          around the catalog and treating every ticket, complaint, and pre-sales question as a
          data point.
        </p>
        <ul data-reveal class="mt-6 flex flex-wrap gap-2" aria-label="Research methods">
          {
            methods.map((m) => (
              <li class="border border-line bg-surface px-3 py-1.5 font-mono text-xs text-muted">
                {m}
              </li>
            ))
          }
        </ul>
        <div class="mt-10 grid gap-6 md:grid-cols-2">
          {
            findings.map((f, i) => (
              <article
                data-reveal
                data-spotlight
                style={`--reveal-delay: ${i * 0.06}s`}
                class="border border-line bg-surface/60 p-6 sm:p-8"
              >
                <span class="font-mono text-xs text-accent">Finding {f.n}</span>
                <h3 class="mt-3 font-display text-xl font-bold tracking-tight text-ink">
                  {f.insight}
                </h3>
                <p class="mt-3 text-sm leading-relaxed text-muted">{f.evidence}</p>
                <p class="mt-4 border-l-2 border-accent/60 pl-4 text-sm leading-relaxed text-ink">
                  <span class="font-mono text-xs text-accent-soft">DECISION → </span>
                  {f.decision}
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Personas -->
    <section class="overflow-hidden border-t border-line">
      <div class="mx-auto max-w-5xl px-5 py-16 sm:px-8 sm:py-24">
        <SectionHeading num="02" title="Personas" ghost="Personas" />
        <p data-reveal class="max-w-2xl leading-relaxed text-muted">
          Two users, one product — and they want different things. The operator pays for it; the
          player lives in it. Every design call had to clear both.
        </p>
        <div class="mt-10 grid gap-6 md:grid-cols-2">
          {
            personas.map((p, i) => (
              <article
                data-reveal
                data-spotlight
                style={`--reveal-delay: ${i * 0.08}s`}
                class="border border-line bg-surface/60 p-6 sm:p-8"
              >
                <div class="flex items-center gap-4">
                  <span
                    aria-hidden="true"
                    class="flex h-12 w-12 items-center justify-center rounded-full font-display text-sm font-black text-bg"
                    style="background: linear-gradient(135deg, #8b5cf6, #e879f9);"
                  >
                    {p.initials}
                  </span>
                  <div>
                    <h3 class="font-display text-xl font-bold tracking-tight text-ink">{p.name}</h3>
                    <p class="font-mono text-xs text-muted">{p.role}</p>
                  </div>
                </div>
                <blockquote class="mt-5 border-l-2 border-accent/60 pl-4 text-sm leading-relaxed text-ink italic">
                  "{p.quote}"
                </blockquote>
                <div class="mt-6 grid gap-5 sm:grid-cols-2">
                  <div>
                    <h4 class="font-mono text-[10px] tracking-[0.2em] text-accent-soft uppercase">
                      Goals
                    </h4>
                    <ul class="mt-2 space-y-1.5">
                      {p.goals.map((g) => (
                        <li class="flex gap-2 text-xs leading-relaxed text-muted">
                          <span aria-hidden="true" class="text-accent">
                            +
                          </span>
                          {g}
                        </li>
                      ))}
                    </ul>
                  </div>
                  <div>
                    <h4 class="font-mono text-[10px] tracking-[0.2em] text-accent-soft uppercase">
                      Frustrations
                    </h4>
                    <ul class="mt-2 space-y-1.5">
                      {p.frustrations.map((fr) => (
                        <li class="flex gap-2 text-xs leading-relaxed text-muted">
                          <span aria-hidden="true" class="text-hot">
                            −
                          </span>
                          {fr}
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- User flow -->
    <section class="overflow-hidden border-t border-line">
      <div class="mx-auto max-w-5xl px-5 py-16 sm:px-8 sm:py-24">
        <SectionHeading num="03" title="User Flow" ghost="Flow" />
        <p data-reveal class="max-w-2xl leading-relaxed text-muted">
          The core loop, from arrest to release. The goal from Finding 01 is visible in the shape
          of it: the sentence is a daily routine of scheduled blocks, with optional work that pays
          off in time and cash — and a punishment branch for skipping it.
        </p>
        <div data-reveal class="mt-10 overflow-x-auto border border-line bg-surface/40 p-4 sm:p-6">
          <svg
            viewBox="0 0 1440 460"
            class="min-w-[1040px]"
            role="img"
            aria-label="User flow: arrest leads to intake (cell and jumpsuit), then into the daily schedule of rollcall, meals, yard and work. Optional work jobs — metal shop, wood shop, laundry, mining — repeat, each taking time off the sentence and paying cash that is spent at the commissary. Missing mandatory schedule blocks escalates to lockdown and then solitary, after which the inmate returns to the schedule. When the time is served the inmate is released and the prison record is cleared, so each sentence stands alone."
          >
            <defs>
              <marker id="arr" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
                <path d="M0,0 L10,5 L0,10 z" fill="#a855f7"></path>
              </marker>
              <marker id="arrhot" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
                <path d="M0,0 L10,5 L0,10 z" fill="#e879f9"></path>
              </marker>
            </defs>
            <style>
              .node { fill: #120b20; stroke: #2b1c47; stroke-width: 1.5; rx: 6; }
              .node-accent { stroke: #a855f7; }
              .node-hot { stroke: #e879f9; stroke-dasharray: 5 4; }
              .lbl { fill: #ece7f8; font: 600 15px "JetBrains Mono Variable", monospace; }
              .sub { fill: #a89bc7; font: 400 11px "JetBrains Mono Variable", monospace; }
              .edge { stroke: #a855f7; stroke-width: 1.5; fill: none; opacity: 0.7; }
              .edge-hot { stroke: #e879f9; stroke-width: 1.5; fill: none; opacity: 0.7; stroke-dasharray: 5 4; }
              .tag { fill: #6f5f93; font: 400 10px "JetBrains Mono Variable", monospace; letter-spacing: 0.1em; }
            </style>

            <!-- spine: arrest -> intake -> schedule -->
            <rect class="node" x="20" y="200" width="120" height="60" rx="6"></rect>
            <text class="lbl" x="42" y="227">ARREST</text>
            <text class="sub" x="42" y="245">caught in the act</text>

            <line class="edge" x1="140" y1="230" x2="176" y2="230" marker-end="url(#arr)"></line>

            <rect class="node" x="180" y="200" width="170" height="60" rx="6"></rect>
            <text class="lbl" x="202" y="227">INTAKE</text>
            <text class="sub" x="202" y="245">cell · jumpsuit</text>

            <line class="edge" x1="350" y1="230" x2="386" y2="230" marker-end="url(#arr)"></line>

            <rect class="node node-accent" x="390" y="200" width="190" height="60" rx="6"></rect>
            <text class="lbl" x="412" y="227">DAILY SCHEDULE</text>
            <text class="sub" x="412" y="245">rollcall · meals · yard</text>
            <text class="tag" x="390" y="190">DAILY LOOP</text>

            <!-- work lane (top) -->
            <path class="edge" d="M580,214 C 612,214 612,90 626,90" marker-end="url(#arr)"></path>

            <rect class="node node-accent" x="630" y="60" width="190" height="60" rx="6"></rect>
            <text class="lbl" x="652" y="87">WORK JOBS</text>
            <text class="sub" x="652" y="105">metal · wood · laundry</text>
            <text class="tag" x="630" y="50">OPTIONAL</text>
            <!-- self loop -->
            <path class="edge" d="M800,60 C 828,28 700,28 680,57" marker-end="url(#arr)"></path>
            <text class="tag" x="716" y="34">REPEAT</text>

            <line class="edge" x1="820" y1="90" x2="854" y2="90" marker-end="url(#arr)"></line>

            <rect class="node" x="858" y="60" width="184" height="60" rx="6"></rect>
            <text class="lbl" x="880" y="87">−TIME · +CASH</text>
            <text class="sub" x="880" y="105">every completion</text>

            <line class="edge" x1="1042" y1="90" x2="1076" y2="90" marker-end="url(#arr)"></line>

            <rect class="node" x="1080" y="60" width="184" height="60" rx="6"></rect>
            <text class="lbl" x="1102" y="87">COMMISSARY</text>
            <text class="sub" x="1102" y="105">spend cash · food · meds</text>

            <!-- payoff drives release -->
            <path class="edge" d="M950,120 C 1090,150 1210,162 1300,198" marker-end="url(#arr)"></path>

            <!-- spine: schedule -> release (time served) -->
            <line class="edge" x1="580" y1="238" x2="1236" y2="232" marker-end="url(#arr)"></line>
            <text class="tag" x="868" y="226">TIME SERVED →</text>

            <rect class="node node-accent" x="1240" y="200" width="170" height="60" rx="6"></rect>
            <text class="lbl" x="1262" y="227">RELEASE</text>
            <text class="sub" x="1262" y="245">time served · freed</text>
            <text class="tag" x="1240" y="190">RECORD CLEARED</text>

            <!-- punishment branch (bottom) -->
            <path class="edge-hot" d="M520,260 C 560,322 592,366 626,368" marker-end="url(#arrhot)"></path>

            <rect class="node node-hot" x="630" y="340" width="180" height="60" rx="6"></rect>
            <text class="lbl" x="652" y="367">LOCKDOWN</text>
            <text class="sub" x="652" y="385">miss mandatory blocks</text>
            <text class="tag" x="630" y="330">MISS EVENTS</text>

            <line class="edge-hot" x1="810" y1="370" x2="846" y2="370" marker-end="url(#arrhot)"></line>

            <rect class="node node-hot" x="850" y="340" width="160" height="60" rx="6"></rect>
            <text class="lbl" x="872" y="367">SOLITARY</text>
            <text class="sub" x="872" y="385">isolation timeout</text>

            <path class="edge-hot" d="M850,372 C 640,420 470,332 478,262" marker-end="url(#arrhot)"></path>
            <text class="tag" x="556" y="418">SERVE IT → BACK TO THE SCHEDULE</text>
          </svg>
        </div>
        <p data-reveal class="mt-6 max-w-2xl text-sm leading-relaxed text-faint">
          Off the loop sits a high-risk exit: hacking the gate control panel to escape — fail it
          and it calls the police. Release wipes the prison record, so the next arrest starts clean.
        </p>
      </div>
    </section>

    <!-- Wireframes -->
    <section class="overflow-hidden border-t border-line">
      <div class="mx-auto max-w-5xl px-5 py-16 sm:px-8 sm:py-24">
        <SectionHeading num="04" title="Wireframes" ghost="Frames" />
        <p data-reveal class="max-w-2xl leading-relaxed text-muted">{wireframeNote}</p>
        <div class="mt-10 grid gap-6 md:grid-cols-3">
          <figure data-reveal class="border border-line bg-surface/60 p-4">
            <svg viewBox="0 0 320 200" class="w-full" role="img" aria-label="Wireframe of the work station menu: header with title and timer, three job rows each with an icon, description lines, and a start button">
              <rect width="320" height="200" fill="#0d0817"></rect>
              <rect x="12" y="12" width="120" height="14" rx="2" fill="#2b1c47"></rect>
              <rect x="252" y="12" width="56" height="14" rx="2" fill="#a855f7" opacity="0.5"></rect>
              {
                [0, 1, 2].map((i) => (
                  <g>
                    <rect x="12" y={40 + i * 50} width="296" height="42" rx="3" fill="none" stroke="#2b1c47" stroke-width="1.5" />
                    <rect x="22" y={48 + i * 50} width="26" height="26" rx="3" fill="#1a112d" />
                    <rect x="58" y={50 + i * 50} width="110" height="8" rx="2" fill="#2b1c47" />
                    <rect x="58" y={64 + i * 50} width="160" height="6" rx="2" fill="#1a112d" />
                    <rect x="246" y={52 + i * 50} width="52" height="18" rx="2" fill="#a855f7" opacity={i === 0 ? "0.6" : "0.25"} />
                  </g>
                ))
              }
            </svg>
            <figcaption class="mt-3 font-mono text-xs text-muted">
              <span class="text-accent">W-01</span> · Work station — pick a job and start
            </figcaption>
          </figure>

          <figure data-reveal style="--reveal-delay: 0.07s" class="border border-line bg-surface/60 p-4">
            <svg viewBox="0 0 320 200" class="w-full" role="img" aria-label="Wireframe of the in-game HUD: sentence timer top right, schedule state top left, progress bar and cash readout bottom left">
              <rect width="320" height="200" fill="#0d0817"></rect>
              <rect x="12" y="12" width="90" height="10" rx="2" fill="#2b1c47"></rect>
              <rect x="12" y="28" width="140" height="6" rx="2" fill="#1a112d"></rect>
              <rect x="236" y="12" width="72" height="22" rx="3" fill="none" stroke="#a855f7" stroke-opacity="0.5" stroke-width="1.5"></rect>
              <rect x="244" y="19" width="56" height="8" rx="2" fill="#2b1c47"></rect>
              <rect x="12" y="156" width="120" height="8" rx="4" fill="#1a112d"></rect>
              <rect x="12" y="156" width="74" height="8" rx="4" fill="#a855f7" opacity="0.6"></rect>
              <rect x="12" y="172" width="44" height="14" rx="7" fill="#1a112d"></rect>
              <rect x="62" y="172" width="44" height="14" rx="7" fill="#1a112d"></rect>
              <circle cx="160" cy="100" r="3" fill="#a855f7" opacity="0.7"></circle>
            </svg>
            <figcaption class="mt-3 font-mono text-xs text-muted">
              <span class="text-accent">W-02</span> · Sentence HUD — timer + schedule state
            </figcaption>
          </figure>

          <figure data-reveal style="--reveal-delay: 0.14s" class="border border-line bg-surface/60 p-4">
            <svg viewBox="0 0 320 200" class="w-full" role="img" aria-label="Wireframe of the commissary shop: cash balance top right, grid of four item tiles each with image area, name line and price button">
              <rect width="320" height="200" fill="#0d0817"></rect>
              <rect x="12" y="12" width="100" height="14" rx="2" fill="#2b1c47"></rect>
              <rect x="240" y="12" width="68" height="16" rx="8" fill="#a855f7" opacity="0.4"></rect>
              {
                [0, 1, 2, 3].map((i) => {
                  const x = 12 + (i % 2) * 152;
                  const y = 42 + Math.floor(i / 2) * 76;
                  return (
                    <g>
                      <rect x={x} y={y} width="144" height="68" rx="3" fill="none" stroke="#2b1c47" stroke-width="1.5" />
                      <rect x={x + 8} y={y + 8} width="36" height="36" rx="3" fill="#1a112d" />
                      <rect x={x + 52} y={y + 12} width="70" height="8" rx="2" fill="#2b1c47" />
                      <rect x={x + 52} y={y + 26} width="48" height="6" rx="2" fill="#1a112d" />
                      <rect x={x + 52} y={y + 44} width="50" height="14" rx="2" fill="#a855f7" opacity="0.3" />
                    </g>
                  );
                })
              }
            </svg>
            <figcaption class="mt-3 font-mono text-xs text-muted">
              <span class="text-accent">W-03</span> · Commissary — spend earned cash
            </figcaption>
          </figure>
        </div>
      </div>
    </section>

    <!-- Shipped UI + outcomes -->
    <section class="overflow-hidden border-t border-line">
      <div class="mx-auto max-w-5xl px-5 py-16 sm:px-8 sm:py-24">
        <SectionHeading num="05" title="Shipped UI" ghost="Shipped" />
        <p data-reveal class="max-w-2xl leading-relaxed text-muted">
          The final interface, in production on live servers. Built straight from the wireframes —
          dark, legible at a glance mid-gameplay, with the sentence timer and schedule state always
          on screen.
        </p>
        <div
          data-reveal
          class="hatch mt-10 flex aspect-video items-center justify-center border border-dashed border-line bg-surface/60"
          role="img"
          aria-label="Final UI screenshots coming soon"
        >
          <span class="px-4 text-center font-mono text-xs text-muted">
            Final UI screenshots / gameplay clip
          </span>
        </div>

        <div data-reveal class="mt-12 grid gap-px border border-line bg-line sm:grid-cols-3">
          {
            [
              ["Live", "running in production on multiplayer servers"],
              ["Commercial", "sold to paying server operators"],
              ["Low-touch", "defaults-first config kept support volume down"],
            ].map(([k, v]) => (
              <div class="bg-surface px-5 py-6">
                <h3 class="text-gradient font-display text-xl font-black tracking-tight">{k}</h3>
                <p class="mt-2 text-sm leading-relaxed text-muted">{v}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- V2 -->
    <section class="overflow-hidden border-t border-line">
      <div class="mx-auto max-w-5xl px-5 py-16 sm:px-8 sm:py-24">
        <SectionHeading num="06" title="Where It's Going" ghost="V2" />
        <div data-reveal class="flex flex-wrap items-center gap-3">
          <p class="max-w-2xl leading-relaxed text-muted">
            V1 proved the loop. V2 is a ground-up rebuild — the same sentence-as-gameplay idea
            opened into a data-driven platform, rebuilt server-authoritative and audit-logged from
            day one.
          </p>
          <span class="border border-accent/40 bg-raised px-2.5 py-1 font-mono text-[10px] tracking-wide text-accent-soft uppercase">
            In development
          </span>
        </div>
